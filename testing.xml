<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationSuite" parallel="tests" thread-count="8">
    <listeners>
        <listener class-name="com.automation.listeners.TestListener"/>
    </listeners>
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome" />
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.InventoryPageTest"/>
            <class name="com.automation.tests.CartPageTest"/>
            <class name="com.automation.tests.CheckoutPageTest"/>
            <class name="com.automation.tests.CheckoutOverviewPageTest"/>
            <class name="com.automation.tests.OrderCompleteTest"/>
        </classes>

    </test>
